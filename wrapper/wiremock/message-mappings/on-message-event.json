{
  "name": "Presence Event",
  "priority": 1,
  "trigger": {
    "type": "message",
    "channel": {
      "type": "websocket",
      "initiatingRequestPattern": {
        "urlPath": "/v1"
      }
    },
    "message": {
      "body": {
        "matchesJsonPath": {
          "expression": "$.message.type",
          "equalTo": "Event"
        }
      }
    }
  },
  "actions": []
}
