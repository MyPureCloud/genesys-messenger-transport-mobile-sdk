{
  "name": "Echo (Health Check)",
  "priority": 1,
  "trigger": {
    "type": "message",
    "channel": {
      "type": "websocket",
      "initiatingRequestPattern": {
        "urlPath": "/api/v2/webmessaging/messages"
      }
    },
    "message": {
      "body": {
        "matchesJsonPath": {
          "expression": "$.action",
          "equalTo": "echo"
        }
      }
    }
  },
  "actions": [
    {
      "type": "send",
      "channelTarget": { "type": "originating" },
      "message": {
        "body": {
          "data": "{\"type\":\"response\",\"class\":\"StructuredMessage\",\"code\":200,\"body\":{\"text\":\"ping\",\"type\":\"Text\",\"direction\":\"Inbound\",\"id\":\"echo_id\"},\"tracingId\":\"{{jsonPath message.body '$.tracingId'}}\"}"
        }
      }
    }
  ]
}
